<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dukes Resto Bar | Best Bar in Trichy | DJ Night</title>
<meta name="description" content="Best bar in Trichy with DJ nights, premium vibe and exclusive offers.">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}
body{background:#000;color:#fff;overflow-x:hidden;}

header{
position:fixed;width:100%;top:0;
display:flex;justify-content:space-between;
padding:15px 30px;background:rgba(0,0,0,0.6);
backdrop-filter:blur(10px);z-index:1000;
}
header h1{color:gold;}
nav a{margin:0 10px;color:#fff;text-decoration:none;}

.hero{
height:100vh;
background:url('https://images.unsplash.com/photo-1541534401786-2077eed87a74') center/cover;
display:flex;align-items:center;justify-content:center;
text-align:center;flex-direction:column;
animation:zoom 12s infinite alternate;
}
@keyframes zoom{
0%{background-size:100%;}
100%{background-size:120%;}
}

.hero h2{font-size:50px;animation:fadeUp 1s ease;}
.hero p{margin:15px 0;}

@keyframes fadeUp{
from{opacity:0;transform:translateY(30px);}
to{opacity:1;transform:translateY(0);}
}

.btn{
background:gold;color:black;
padding:12px 25px;margin:10px;
text-decoration:none;border-radius:30px;
transition:0.3s;
}
.btn:hover{background:white;}

.section{
padding:80px 20px;text-align:center;
opacity:0;transform:translateY(50px);
transition:0.6s;
}
.section.show{opacity:1;transform:translateY(0);}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;margin-top:30px;
}

.card{
background:#111;padding:20px;border-radius:15px;
transition:0.4s;
}
.card:hover{
transform:translateY(-10px) scale(1.03);
box-shadow:0 0 20px gold;
}

.gallery img{
width:100%;border-radius:10px;
transition:0.4s;
}
.gallery img:hover{transform:scale(1.05);}

footer{
text-align:center;padding:20px;background:#000;
}

.sticky{
position:fixed;bottom:15px;right:15px;
background:gold;color:black;
padding:15px;border-radius:50px;
}

</style>
</head>

<body>

<header>
<h1>Dukes</h1>
<nav>
<a href="#about">About</a>
<a href="#offers">Offers</a>
<a href="#events">Events</a>
<a href="#gallery">Gallery</a>
<a href="#contact">Contact</a>
</nav>
</header>

<section class="hero">
<h2>🔥 Best Bar in Trichy</h2>
<p>DJ Nights | Premium Vibe | Party Spot</p>
<a href="tel:+919999999999" class="btn">Book Table</a>
<a href="#offers" class="btn">View Offers</a>
</section>

<section id="about" class="section">
<h2>About Dukes</h2>
<p>Top-rated resto bar in Trichy with DJ nights, premium ambience and unforgettable party vibe.</p>
</section>

<section id="offers" class="section">
<h2>🔥 Offers</h2>
<div class="cards">
<div class="card">Buy 2 Get 1 Free</div>
<div class="card">Free Beer on Booking</div>
<div class="card">Birthday Surprise</div>
</div>
</section>

<section id="events" class="section">
<h2>🎧 Weekly Events</h2>
<div class="cards">
<div class="card">Friday DJ Night</div>
<div class="card">Saturday Party Night</div>
<div class="card">Sunday Chill</div>
</div>
</section>

<section id="gallery" class="section gallery">
<h2>📸 Gallery</h2>
<div class="cards">
<img src="https://images.unsplash.com/photo-1516455590571-18256e5bb9ff">
<img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836">
<img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30">
</div>
</section>

<section id="contact" class="section">
<h2>📍 Contact</h2>
<p>Trichy, Tamil Nadu</p>
<p>📞 +91 99999 99999</p>
<a href="https://wa.me/919999999999" class="btn">WhatsApp</a>
</section>

<footer>
<p>© 2026 Dukes Resto Bar | Best Bar in Trichy</p>
</footer>

<a href="tel:+919999999999" class="sticky">📞</a>

<script>
const sections=document.querySelectorAll('.section');
window.addEventListener('scroll',()=>{
sections.forEach(sec=>{
const top=window.scrollY;
const offset=sec.offsetTop-400;
if(top>offset){sec.classList.add('show');}
});
});
</script>

</body>
</html>
